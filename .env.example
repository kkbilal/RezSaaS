# Local development only. Replace the password before starting PostgreSQL.
REZSAAS_POSTGRES_HOST=localhost
REZSAAS_POSTGRES_DB=rezsaas
REZSAAS_POSTGRES_USER=rezsaas
REZSAAS_POSTGRES_PASSWORD=change-me-before-starting-postgres
REZSAAS_POSTGRES_PORT=5432

# Frontend (Next.js) — copy to src/Apps/RezSaaS.Web/.env.local
NEXT_PUBLIC_REZSAAS_API_BASE_URL=http://localhost:5252
