root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.cs]
indent_size = 4

[*.csproj]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[**/Infrastructure/Persistence/Migrations/*.cs]
generated_code = true
dotnet_analyzer_diagnostic.severity = none
