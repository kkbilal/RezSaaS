# RezSaaS.Web ortam degiskenleri
# Bu dosyayi .env.local olarak kopyalayip degerleri doldurun.
#
#   cp .env.example .env.local
#
# NOT: production build (`pnpm build`) REZSAAS_API_BASE_URL olmadan BASARISIZ olur
# ("REZSAAS_API_BASE_URL environment variable is required in production").

# Sunucu tarafi (RSC / server component) API cagrilari icin taban URL.
# Ayni makinede kosuyorsa API'nin dinledigi adres.
REZSAAS_API_BASE_URL=http://localhost:5000

# Tarayici tarafi API cagrilari icin taban URL. Tarayiciya GOMULUR -- sir koymayin.
NEXT_PUBLIC_REZSAAS_API_BASE_URL=http://localhost:5000


# ---------------------------------------------------------------------------
# DEPLOY BLOKAJI -- backend tarafinda ayarlanir, burada degil. Hatirlatma icin:
#
# API'nin `Security:UnsafeRequestOrigins:AllowedOrigins` ayari PROD'DA BOS
# (src/Apps/RezSaaS.Api/appsettings.json). UnsafeRequestOriginMiddleware
# fail-closed calisir: Origin eslesmezse 403 doner.
#
# Bu liste doldurulmazsa RANDEVU OLUSTURMA DAHIL her POST/PUT/PATCH/DELETE
# 403 doner ve uygulama fiilen calismaz.
#
# Deploy ederken API'ye su ortam degiskenini verin (web'in gercek origin'i):
#   Security__UnsafeRequestOrigins__AllowedOrigins__0=https://app.rezsaas.com
#
# Detay: docs/29-frontend-ia-sayfa-envanteri.md -> Lansman blokaji #4 / B7
# ---------------------------------------------------------------------------
