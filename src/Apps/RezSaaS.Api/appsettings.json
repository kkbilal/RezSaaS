{
  "Identity": {
    "AuthenticationPermitLimit": 10,
    "AuthenticationWindowMinutes": 1,
    "DeliveryMode": "Unconfigured",
    "LockoutMinutes": 15,
    "MaxFailedAccessAttempts": 5,
    "PasswordRequiredLength": 12,
    "PasswordRequiredUniqueChars": 4,
    "RequireConfirmedEmail": true
  },
  "Booking": {
    "ExpiryWorker": {
      "Enabled": true,
      "InitialDelay": "00:00:30",
      "Interval": "00:05:00",
      "TenantBatchSize": 500
    },
    "Security": {
      "AppointmentRequestPermitLimit": 12,
      "AppointmentRequestWindowMinutes": 1,
      "DefaultResponseBuffer": "02:00:00",
      "MaxConcurrentPendingRequestsPerUser": 3,
      "MaxRequestsPerUserPerDay": 20
    }
  },
  "Organization": {
    "PublicDiscovery": {
      "DefaultTake": 20,
      "MaxTake": 50,
      "PermitLimit": 60,
      "WindowMinutes": 1
    }
  },
  "Security": {
    "UnsafeRequestOrigins": {
      "AllowedOrigins": []
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
