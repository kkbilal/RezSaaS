{
  "Admin": {
    "AbuseRisk": {
      "AccountClosureExecutionEnabled": true
    }
  },
  "Identity": {
    "DeliveryMode": "DevelopmentSink",
    "RequireConfirmedEmail": false
  },
  "Security": {
    "UnsafeRequestOrigins": {
      "AllowedOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000"
      ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
